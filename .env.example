# Supabase — get these from supabase.com → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Maps — enable Maps SDK (iOS + Android) + Places API in Google Cloud Console
# This key is embedded in the app bundle — restrict it to Maps SDK + Places API only
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-client-key-here

# OpenWeather (optional — for future weather features)
EXPO_PUBLIC_OPENWEATHER_API_KEY=your-openweather-key-here
